# ─── Affiliate Networks ───────────────────────────────────────────────────────
IMPACT_API_KEY=your_impact_radius_api_key
IMPACT_ACCOUNT_SID=your_impact_account_sid
# Comma-separated "Label:CampaignId" pairs for targeted brand catalog queries.
# Find campaign IDs in your Impact dashboard under Brands > [Brand] > Settings.
IMPACT_CAMPAIGN_IDS=Nike:12345,Jordan:67890,Adidas:11111,Foot Locker:22222

CJ_API_KEY=your_cj_affiliate_api_key
CJ_WEBSITE_ID=your_cj_website_id

# ─── Social / Automation ──────────────────────────────────────────────────────
ROBINREACH_API_KEY=your_robinreach_api_key
ROBINREACH_BRAND_ID=your_robinreach_brand_id
ROBINREACH_ACCOUNT_ID=your_robinreach_x_social_profile_id

# ─── YouTube ──────────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_CHANNEL_ID=your_youtube_channel_id

# ─── Sanity CMS ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_sanity_write_token
SANITY_WEBHOOK_SECRET=your_webhook_secret

# ─── App Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://asneakerlife.com
CRON_SECRET=your_cron_secret_for_vercel_cron

# ─── Switchy ──────────────────────────────────────────────────────────────────
SWITCHY_API_KEY=your_switchy_api_key
SWITCHY_DOMAIN=links.asneakerlife.com
